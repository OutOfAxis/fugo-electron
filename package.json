{
  "name": "OutofaxisLimted.FugoDigitalSignagePlayer",
  "version": "1.10.0",
  "description": "Fugo CMS Windows Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -w"
  },
  "repository": "https://github.com/OutOfAxis/fugo-electron",
  "keywords": [
    "digital signage",
    "dooh"
  ],
  "author": "outofaxis limited",
  "devDependencies": {
    "electron": "^23.1.4",
    "electron-builder": "^23.6.0"
  },
  "build": {
    "win": {
      "target": "appx"
    },
    "appId": "ai.fugo.windowplayer",
    "mac": {
      "category": "public.app-category.business"
    },
    "appx": {
      "publisher": "CN=CDD4C721-E148-4324-85C6-9CA4839D9E7F",
      "applicationId": "ai.fugo.windowsplayer",
      "backgroundColor": "#7048e8",
      "displayName": "Fugo – Digital Signage Player",
      "customExtensionsPath": "appmanifest.xml",
      "publisherDisplayName": "outofaxis limited"
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "semi": false
  },
  "dependencies": {
    "electron-log": "^4.4.8",
    "electron-updater": "^5.3.0",
    "node-fetch": "^2.6.9"
  }
}